# Required
VIDEO_DB_DSN=postgres://postgres:postgres@localhost:5432/litenergy?sslmode=disable
BACKEND_API_BASE_URL=http://localhost:8081/api/v1
BACKEND_SERVICE_TOKEN=service-token-with-core-tasks-moderate-scope

# Optional runtime
VIDEO_BATCH_SIZE=15
VIDEO_POLL_SEC=2
VIDEO_WORKER_ID=video-worker-1
VIDEO_ANALYZER_ENGINE=cv_match
VIDEO_ANALYZER_TIMEOUT_SEC=1200
VIDEO_DOWNLOAD_DIR=/tmp/video-jobs
VIDEO_DOWNLOAD_CONNECT_TIMEOUT_SEC=10
VIDEO_DOWNLOAD_READ_TIMEOUT_SEC=120
VIDEO_DOWNLOAD_MAX_SIZE_MB=500
VIDEO_CLEANUP_DOWNLOADED=true
VIDEO_DOWNLOADER=auto
# Optional proxy for video downloads. Applied to direct HTTP downloads and yt-dlp.
# Supports http://, https://, socks5:// and socks5h:// when PySocks is installed.
# VIDEO_PROXY_URL=http://user:password@proxy-host:3128
VIDEO_YTDLP_FORMAT=best[ext=mp4]/best
VIDEO_YTDLP_TIMEOUT_SEC=300
# Use this for Instagram/TikTok accounts or regional restrictions when public extraction fails.
# Mount the cookies file into the container and point this env to it.
# VIDEO_YTDLP_COOKIES_FILE=/run/secrets/video_ytdlp_cookies.txt
# VIDEO_YTDLP_EXTRA_ARGS=--user-agent Mozilla/5.0

# Optional analyzer command (legacy shell template)
# Must print JSON to stdout: {"status":"approved|rejected|manual|invalid","result":{...}}
# Placeholders: {video_path}, {video_id}
# Use VIDEO_ANALYZER_ENGINE=subprocess to enable it.
# VIDEO_ANALYZER_CMD=python analyze_video_sam3.py --video-path "{video_path}" --video-id "{video_id}"

# Optional OpenCV analyzer settings. This mode has no torch/transformers dependency.
VIDEO_CV_REFS_DIRS=refs/can|refs/chips|refs/logo
VIDEO_CV_SAMPLE_FPS=0.35
VIDEO_CV_MAX_SAMPLED_FRAMES=12
VIDEO_CV_MAX_WIDTH=720
VIDEO_CV_CROP_MODE=5
VIDEO_CV_ORB_FEATURES=900
VIDEO_CV_ORB_DISTANCE_THRESHOLD=58
VIDEO_CV_APPROVE_MIN_GOOD_MATCHES=18
VIDEO_CV_MANUAL_MIN_GOOD_MATCHES=8
VIDEO_CV_APPROVE_SCORE_THRESHOLD=0.55
VIDEO_CV_MANUAL_SCORE_THRESHOLD=0.35

# Optional SAM3 analyzer settings
VIDEO_SAM3_MODEL_ID=facebook/sam3
VIDEO_SAM3_PROMPTS=lit energy can|lit energy drink can|energy drink can
VIDEO_SAM3_SAMPLE_FPS=2
VIDEO_SAM3_DTYPE=auto
# 0 keeps model default resolution. 768/560 is faster but may reduce accuracy.
VIDEO_SAM3_IMAGE_SIZE=0
VIDEO_SAM3_EARLY_APPROVE=true
VIDEO_SAM3_MAX_SAMPLED_FRAMES=0
VIDEO_SAM3_SCORE_THRESHOLD=0.5
VIDEO_SAM3_MASK_THRESHOLD=0.5
VIDEO_SAM3_MIN_MASK_AREA_RATIO=0.001
VIDEO_SAM3_APPROVE_MIN_HITS=3
VIDEO_SAM3_APPROVE_MIN_UNIQUE_SECONDS=2

# Optional fast CPU analyzer settings
VIDEO_FAST_MODEL_ID=openai/clip-vit-base-patch32
VIDEO_FAST_REFS_DIRS=refs/can|refs/chips|refs/logo
VIDEO_FAST_TEXT_PROMPTS=lit energy drink can|lit energy chips|lit energy logo|energy drink can
VIDEO_FAST_DEVICE=cpu
VIDEO_FAST_SAMPLE_FPS=0.25
VIDEO_FAST_MAX_SAMPLED_FRAMES=8
VIDEO_FAST_MAX_WIDTH=512
VIDEO_FAST_CROP_MODE=5
VIDEO_FAST_APPROVE_REF_THRESHOLD=0.30
VIDEO_FAST_APPROVE_TEXT_THRESHOLD=0.20
VIDEO_FAST_MANUAL_REF_THRESHOLD=0.25
VIDEO_FAST_MANUAL_TEXT_THRESHOLD=0.16
VIDEO_FAST_APPROVE_MIN_HITS=1

# Optional: use these on the VPS only when the image was built with PREFETCH_FAST_MODEL=true.
# They prevent slow runtime attempts to reach Hugging Face if the host has restricted outbound network.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
